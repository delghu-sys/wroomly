{
  "name": "michigan-nest",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:rls": "node --env-file=.env.local scripts/test-rls-self-promote.mjs",
    "test:unit": "node --test tests/unit/*.test.ts",
    "sentry:check": "node --env-file=.env.sentry-build-plugin scripts/sentry-issues.mjs --include-event",
    "seed:placeholders": "node scripts/generateSeedPlaceholders.mjs",
    "seed:import": "node --env-file=.env.local scripts/importSeed.mjs",
    "partners:photos": "node scripts/downloadA2Photos.mjs",
    "partners:import": "node --env-file=.env.local scripts/importPartners.mjs",
    "partners:scrape:mr": "node scripts/scrapeMichiganRental.mjs",
    "partners:import:mr": "node --env-file=.env.local scripts/importPartners.mjs --file=michiganrental",
    "partners:teardown:mr": "node --env-file=.env.local scripts/teardownPartner.mjs --source-name=MichiganRental",
    "partners:scrape:cmb": "node --env-file=.env.local scripts/scrapeCMB.mjs",
    "partners:import:cmb": "node --env-file=.env.local scripts/importPartners.mjs --file=cmb",
    "partners:teardown:cmb": "node --env-file=.env.local scripts/teardownPartner.mjs --source-name=\"CMB Management\"",
    "seed:teardown": "node --env-file=.env.local scripts/teardownSeed.mjs",
    "seed:stats": "node --env-file=.env.local scripts/seedStats.mjs",
    "listings:backfill-geocode": "node --env-file=.env.local scripts/backfillListingGeocode.mjs --dry-run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.2",
    "@base-ui/react": "^1.4.1",
    "@hookform/resolvers": "^5.2.2",
    "@phosphor-icons/react": "^2.1.10",
    "@sentry/nextjs": "^10.53.1",
    "@stripe/stripe-js": "^9.4.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@types/leaflet": "^1.9.21",
    "@types/mapbox-gl": "^3.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.14.0",
    "mapbox-gl": "^3.23.1",
    "motion": "^12.38.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.75.0",
    "resend": "^6.12.3",
    "sonner": "^2.0.7",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "shadcn": "^4.7.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
